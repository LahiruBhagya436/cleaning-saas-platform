generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  customer
  staff
  coordinator
  admin
  superadmin
}

enum ServiceCategory {
  residential
  commercial
  specialty
}

enum BookingStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
}

enum RecurrenceType {
  none
  weekly
  biweekly
  monthly
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  void
}

enum RutClaimStatus {
  pending
  submitted
  approved
  rejected
}

enum NotificationChannel {
  email
  sms
  push
}

enum SubscriptionTier {
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

// ─── Companies (tenants) ───────────────────────────────────────────────────────

// Each row here is one cleaning company subscribing to the platform.
// superadmin (platform-owner) users have companyId = null; every other
// user/service/booking/invoice belongs to exactly one company.
model Company {
  id                 String             @id @default(uuid())
  name               String
  slug               String             @unique
  logoUrl            String?
  primaryColor       String             @default("#2563A8")
  contactEmail       String
  contactPhone       String?
  addressLine1       String?
  city               String?            @default("Stockholm")
  postalCode         String?
  stripeAccountId    String?
  stripeOnboarded    Boolean            @default(false)
  subscriptionTier   SubscriptionTier   @default(starter)
  subscriptionStatus SubscriptionStatus @default(trialing)
  trialEndsAt        DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  users              User[]
  services           Service[]
  bookings           Booking[]
  invoices           Invoice[]

  @@map("companies")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id                 String          @id @default(uuid())
  companyId          String?
  email              String          @unique
  phone              String?         @unique
  fullName           String
  passwordHash       String?
  googleId           String?         @unique
  role               UserRole        @default(customer)
  preferredLanguage  String          @default("sv")
  isActive           Boolean         @default(true)
  personnummerEnc    String?

  // ── Worker / staff profile fields ─────────────────────────────────────────
  // Only populated for role = staff | coordinator. Stored encrypted where
  // sensitive (personnummerEnc, bankAccountEnc).
  addressLine1       String?
  city               String?
  postalCode         String?
  bankAccountEnc     String?         // encrypted IBAN / bank account number
  bankClearingNo     String?         // bank clearing / sort code (not secret)
  emergencyContact   String?         // name of emergency contact
  emergencyPhone     String?         // phone of emergency contact
  hireDate           DateTime?       @db.Date
  employmentNotes    String?         // internal admin-only notes

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  company            Company?        @relation(fields: [companyId], references: [id])
  properties         Property[]
  bookingsAsCustomer Booking[]       @relation("CustomerBookings")
  bookingsAsStaff    Booking[]       @relation("StaffBookings")
  schedules          StaffSchedule[]
  reviews            Review[]        @relation("CustomerReviews")
  staffReviews       Review[]        @relation("StaffReviews")
  notifications      Notification[]
  refreshTokens      RefreshToken[]

  @@index([companyId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Properties ───────────────────────────────────────────────────────────────

model Property {
  id            String    @id @default(uuid())
  userId        String
  label         String?
  addressLine1  String
  city          String    @default("Stockholm")
  postalCode    String
  areaSqm       Int?
  floors        Int       @default(1)
  accessCodeEnc String?
  entryNotes    String?
  hasPets       Boolean   @default(false)
  isPrimary     Boolean   @default(false)
  lat           Float?
  lng           Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@map("properties")
}

// ─── Services ─────────────────────────────────────────────────────────────────

model Service {
  id               String          @id @default(uuid())
  companyId        String
  name             String
  nameSv           String
  category         ServiceCategory @default(residential)
  basePricePerHour Decimal         @db.Decimal(10, 2)
  fixedPrice       Decimal?        @db.Decimal(10, 2)
  rutEligible      Boolean         @default(true)
  vatRate          Decimal         @default(0.25) @db.Decimal(5, 4)
  minDurationMins  Int             @default(60)
  description      String?
  descriptionSv    String?
  isActive         Boolean         @default(true)
  sortOrder        Int             @default(0)
  createdAt        DateTime        @default(now())

  company          Company         @relation(fields: [companyId], references: [id])
  bookingItems     BookingItem[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("services")
}

// ─── Bookings ─────────────────────────────────────────────────────────────────

model Booking {
  id                 String          @id @default(uuid())
  companyId          String
  userId             String
  propertyId         String
  staffId            String?
  scheduledAt        DateTime
  estimatedEndAt     DateTime
  durationMinutes    Int
  status             BookingStatus   @default(pending)
  recurrence         RecurrenceType  @default(none)
  recurrenceEndDate  DateTime?
  parentBookingId    String?
  totalPriceExclVat  Decimal         @db.Decimal(10, 2)
  vatAmount          Decimal         @db.Decimal(10, 2)
  rutDeduction       Decimal         @default(0) @db.Decimal(10, 2)
  customerPays       Decimal         @db.Decimal(10, 2)
  cancellationReason String?
  completionNotes    String?
  notes              String?
  staffArrivedAt     DateTime?
  staffCompletedAt   DateTime?
  staffLocationLat   Float?
  staffLocationLng   Float?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  company            Company         @relation(fields: [companyId], references: [id])
  customer           User            @relation("CustomerBookings", fields: [userId], references: [id])
  staff              User?           @relation("StaffBookings",    fields: [staffId], references: [id])
  property           Property        @relation(fields: [propertyId], references: [id])
  parentBooking      Booking?        @relation("RecurringSeries",  fields: [parentBookingId], references: [id])
  childBookings      Booking[]       @relation("RecurringSeries")
  items              BookingItem[]
  invoice            Invoice?
  photos             BookingPhoto[]
  reviews            Review[]
  checklist          ChecklistItem[]

  @@index([companyId])
  @@map("bookings")
}

model BookingItem {
  id        String   @id @default(uuid())
  bookingId String
  serviceId String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])

  @@map("booking_items")
}

model BookingPhoto {
  id         String   @id @default(uuid())
  bookingId  String
  type       String
  s3Key      String
  s3Url      String
  uploadedAt DateTime @default(now())

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("booking_photos")
}

model ChecklistItem {
  id        String  @id @default(uuid())
  bookingId String
  label     String
  labelSv   String
  completed Boolean @default(false)
  sortOrder Int     @default(0)

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

// ─── Staff Schedules ──────────────────────────────────────────────────────────

model StaffSchedule {
  id          String   @id @default(uuid())
  staffId     String
  workDate    DateTime @db.Date
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  notes       String?

  staff       User     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, workDate])
  @@map("staff_schedules")
}

// ─── Invoices ─────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  bookingId       String        @unique
  invoiceNumber   String
  labourCost      Decimal       @db.Decimal(10, 2)
  materialsCost   Decimal       @default(0) @db.Decimal(10, 2)
  vatAmount       Decimal       @db.Decimal(10, 2)
  rutDeduction    Decimal       @default(0) @db.Decimal(10, 2)
  customerPays    Decimal       @db.Decimal(10, 2)
  stripePaymentId String?
  fortnoxId       String?
  status          InvoiceStatus @default(draft)
  issuedAt        DateTime      @default(now())
  dueAt           DateTime
  paidAt          DateTime?
  pdfS3Key        String?
  pdfUrl          String?
  emailSentAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company         Company       @relation(fields: [companyId], references: [id])
  booking         Booking       @relation(fields: [bookingId], references: [id])
  rutClaim        RutClaim?

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@map("invoices")
}

model RutClaim {
  id                      String         @id @default(uuid())
  invoiceId               String         @unique
  customerPersonnummerEnc String
  claimAmount             Decimal        @db.Decimal(10, 2)
  skatteverketRef         String?
  claimStatus             RutClaimStatus @default(pending)
  submittedAt             DateTime?
  approvedAt              DateTime?
  rejectionReason         String?
  retryCount              Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  invoice                 Invoice        @relation(fields: [invoiceId], references: [id])

  @@map("rut_claims")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  bookingId String
  userId    String
  staffId   String
  rating    Int
  comment   String?
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id])
  customer  User     @relation("CustomerReviews", fields: [userId],   references: [id])
  staff     User     @relation("StaffReviews",    fields: [staffId],  references: [id])

  @@unique([bookingId, userId])
  @@map("reviews")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String              @id @default(uuid())
  userId    String
  channel   NotificationChannel
  type      String
  subject   String?
  body      String
  metadata  Json?
  sentAt    DateTime?
  failedAt  DateTime?
  error     String?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
