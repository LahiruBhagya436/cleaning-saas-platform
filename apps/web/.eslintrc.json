{
  "root": true,
  "env": { "browser": true, "es2021": true, "node": true },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  }
}
